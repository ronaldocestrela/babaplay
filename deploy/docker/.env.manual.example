# SQL Server
SQL_EXTERNAL_PORT=1433
SQL_SA_PASSWORD=YourStrong@Passw0rd123
MASTER_DB_CONNECTION_STRING=Server=sqlserver,1433;Database=BabaPlay_Master;User Id=sa;Password=YourStrong@Passw0rd123;TrustServerCertificate=true;

# JWT
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_AT_LEAST_256_BITS
JWT_ISSUER=BabaPlay.Api
JWT_AUDIENCE=BabaPlay.Clients
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# API/CORS
CORS_ALLOWED_ORIGIN=http://localhost:8080
ASSOCIATION_INVITE_ACCEPT_LINK_BASE_URL=http://localhost:8080/invite/accept
ASSOCIATION_INVITE_TOKEN_EXPIRES_HOURS=24

# Tenant logo storage (Cloudinary)
TENANT_LOGO_STORAGE_PROVIDER=Local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=tenant-logos

# Resend (opcional, manter vazio se nao for usar envio real)
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
RESEND_FROM_EMAIL=noreply@babaplay.app
RESEND_FROM_NAME=BabaPlay

# Frontend build-time
WEB_VITE_API_URL=http://localhost:5050
